{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-vcpkg",
      "displayName": "Windows vcpkg",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build-vcpkg",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "WUWE_ENABLE_SQLITE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vcpkg-debug",
      "configurePreset": "windows-vcpkg",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "windows-vcpkg-debug",
      "configurePreset": "windows-vcpkg",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
